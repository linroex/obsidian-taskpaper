{
  "name": "taskpaper-obsidian",
  "version": "0.1.0",
  "description": "Obsidian plugin for editing TaskPaper (.taskpaper) files.",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "compile": "tsc --noEmit",
    "test": "npm run test:unit && npm run test:e2e && npm run test:e2e:palettes && npm run test:e2e:commands && npm run test:e2e:sidebar && npm run test:e2e:view && npm run test:e2e:calendar && npm run test:e2e:capture",
    "test:unit": "esbuild test/editor.test.ts --bundle --platform=node --format=cjs --outfile=out-test/editor.cjs && node out-test/editor.cjs",
    "test:e2e": "esbuild test/e2e.test.ts --bundle --platform=node --format=cjs --alias:obsidian=./test/stubs/obsidian.ts --external:jsdom --outfile=out-test/e2e.cjs && node out-test/e2e.cjs",
    "test:e2e:palettes": "esbuild test/e2e.palettes.test.ts --bundle --platform=node --format=cjs --alias:obsidian=./test/stubs/obsidian.ts --external:jsdom --outfile=out-test/e2e.palettes.cjs && node out-test/e2e.palettes.cjs",
    "test:e2e:commands": "esbuild test/e2e.commands.test.ts --bundle --platform=node --format=cjs --alias:obsidian=./test/stubs/obsidian.ts --external:jsdom --outfile=out-test/e2e.commands.cjs && node out-test/e2e.commands.cjs",
    "test:e2e:sidebar": "esbuild test/e2e.sidebar.test.ts --bundle --platform=node --format=cjs --alias:obsidian=./test/stubs/obsidian.ts --external:jsdom --outfile=out-test/e2e.sidebar.cjs && node out-test/e2e.sidebar.cjs",
    "test:e2e:view": "esbuild test/e2e.view.test.ts --bundle --platform=node --format=cjs --alias:obsidian=./test/stubs/obsidian.ts --external:jsdom --outfile=out-test/e2e.view.cjs && node out-test/e2e.view.cjs",
    "test:e2e:calendar": "esbuild test/e2e.calendar.test.ts --bundle --platform=node --format=cjs --alias:obsidian=./test/stubs/obsidian.ts --external:jsdom --outfile=out-test/e2e.calendar.cjs && node out-test/e2e.calendar.cjs",
    "test:e2e:capture": "esbuild test/e2e.capture.test.ts --bundle --platform=node --format=cjs --alias:obsidian=./test/stubs/obsidian.ts --external:jsdom --outfile=out-test/e2e.capture.cjs && node out-test/e2e.capture.cjs"
  },
  "dependencies": {
    "@taskpaper/core": "*"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.18.0",
    "@codemirror/commands": "^6.3.0",
    "@codemirror/language": "^6.10.0",
    "@codemirror/search": "^6.5.0",
    "@codemirror/state": "^6.4.0",
    "@codemirror/view": "^6.24.0",
    "@types/node": "^18.19.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.0",
    "jsdom": "^29.1.1",
    "obsidian": "^1.5.7",
    "typescript": "^5.4.0"
  }
}
