{
  "name": "taskpaper-obsidian",
  "version": "0.1.0",
  "description": "Obsidian plugin for editing TaskPaper (.taskpaper) files.",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "compile": "tsc --noEmit",
    "test": "esbuild test/editor.test.ts --bundle --platform=node --format=cjs --outfile=out-test/editor.cjs && node out-test/editor.cjs"
  },
  "dependencies": {
    "@taskpaper/core": "*"
  },
  "devDependencies": {
    "@codemirror/commands": "^6.3.0",
    "@codemirror/language": "^6.10.0",
    "@codemirror/state": "^6.4.0",
    "@codemirror/view": "^6.24.0",
    "@types/node": "^18.19.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.0",
    "obsidian": "^1.5.7",
    "typescript": "^5.4.0"
  }
}
